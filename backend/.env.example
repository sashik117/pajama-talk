PAJAMA_APP_NAME=PajamaTalk API
PAJAMA_ENV=local
PAJAMA_DATABASE_URL=sqlite:///./pajamatalk.db
# Docker/Postgres example:
# PAJAMA_DATABASE_URL=postgresql+psycopg://pajama:pajama@localhost:5432/pajamatalk
PAJAMA_JWT_SECRET=change-me-in-dev
PAJAMA_JWT_EXPIRE_MINUTES=10080
PAJAMA_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3175,http://127.0.0.1:3175
PAJAMA_GEMINI_API_KEY=
PAJAMA_GEMINI_MODEL=gemini-2.0-flash
PAJAMA_OPENAI_API_KEY=
